{
  "name": "@bungres/orm",
  "version": "0.6.0",
  "description": "Type-safe ORM for Postgres using Bun native SQL",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.3.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "author": "aniket khote",
  "repository": {
    "type": "git",
    "url": "https://github.com/bungres/bungres.git",
    "directory": "packages/bungres-orm"
  },
  "bugs": {
    "url": "https://github.com/bungres/bungres/issues"
  },
  "homepage": "https://github.com/bungres/bungres#readme",
  "keywords": [
    "bun",
    "postgres",
    "orm",
    "sql",
    "database",
    "typescript"
  ],
  "scripts": {
    "build:types": "tsc --emitDeclarationOnly",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm && npm run build:types",
    "dev": "bun --watch src/index.ts",
    "test": "bun test src/tests"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "latest"
  }
}